		<Item class="Folder" referent="RBXF5C42DAC46FD4CEB886835539D762AE4">
			<Properties>
				<BinaryString name="AttributesSerialize"></BinaryString>
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<string name="Name">Language</string>
				<int64 name="SourceAssetId">-1</int64>
				<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
			</Properties>
			<Item class="ModuleScript" referent="RBXF1F3B7A04EAB422FAB59D43F86CCE159">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Languages = {}
for _, language in (script.Parent.Languages:GetChildren()) do
	Languages[language.Name] = require(language)
end

local Autocomplete = {}

function Autocomplete.Get(self: Autocomplete, language: string, text: string): {[number]: string}
	text = string.upper(text)

	local commands = Languages[language].Commands
	local suggestions = {}
	for command, data in (commands) do
		local startIndex, endIndex = string.find(command, text, nil, true)
		if startIndex then
			suggestions[command] = #command - #text
		end
	end
	
	local ordered = {}
	for command, points in (suggestions) do
		table.insert(ordered, {
			Command = command,
			Points = points
		})
	end
	
	table.sort(ordered, function(a, b)
		return a.Points < b.Points
	end)
	
	local result = {}
	for index, data in (ordered) do
		table.insert(result, data.Command)
	end
	
	return result
end

type Autocomplete = typeof(Autocomplete)
return Autocomplete]]></ProtectedString>
					<string name="ScriptGuid">{db504e27-b89d-9664-59b2-a051e33ab77e}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
